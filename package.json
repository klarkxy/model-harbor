{
  "name": "modelharbor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ModelHarbor - lightweight dashboard-first LLM API router",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=22.10.0",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620",
  "scripts": {
    "predev": "node scripts/predev-port.mjs && pnpm --filter @modelharbor/shared build",
    "kill:port": "node scripts/predev-port.mjs",
    "dev": "pnpm -r --parallel --stream dev",
    "dev:api": "pnpm --filter @modelharbor/api dev",
    "dev:web": "pnpm --filter @modelharbor/web dev",
    "prebuild": "pnpm --filter @modelharbor/shared build",
    "build": "pnpm -r build",
    "pretypecheck": "pnpm --filter @modelharbor/shared build",
    "typecheck": "pnpm -r typecheck",
    "pretest": "pnpm --filter @modelharbor/shared build",
    "test": "pnpm -r test",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  }
}
